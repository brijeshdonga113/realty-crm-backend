# Firebase configuration
# Copy this file to .env.local and fill in your Firebase project values.
#
# Steps:
#   1. Go to Firebase Console → Project Settings → Your apps → Web app
#   2. Copy the config values below
#   3. In Firebase Console → Authentication → Sign-in method → Enable "Email/Password"
#   4. In Firebase Console → Firestore Database → Create database (Native mode)
#
# Without these vars the app runs in localStorage dev mode (no persistence across devices).

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Google Calendar integration (optional)
# Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Also enable "Google Calendar API" in APIs & Services → Library
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Razorpay (subscriptions)
# dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Create two Plans in Razorpay Dashboard → Products → Subscriptions → Plans
RAZORPAY_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxx
RAZORPAY_YEARLY_PLAN_ID=plan_xxxxxxxxxxxx
# Razorpay Dashboard → Settings → Webhooks → add endpoint, copy secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# WhatsApp via WATI (wati.io)
# WATI Dashboard → Account → API → copy endpoint URL and access token
WATI_API_ENDPOINT=https://live-mt-server.wati.io/YOUR_ACCOUNT_ID
WATI_API_TOKEN=your_wati_bearer_token

# Firebase Admin SDK (for server-side API routes)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
