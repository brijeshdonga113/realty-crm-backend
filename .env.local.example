# Firebase configuration
# Copy this file to .env.local and fill in your Firebase project values.
#
# Steps:
#   1. Go to Firebase Console → Project Settings → Your apps → Web app
#   2. Copy the config values below
#   3. In Firebase Console → Authentication → Sign-in method → Enable "Email/Password"
#   4. In Firebase Console → Firestore Database → Create database (Native mode)
#
# Without these vars the app runs in localStorage dev mode (no persistence across devices).

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here

# Google Calendar integration (optional)
# Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Also enable "Google Calendar API" in APIs & Services → Library
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
