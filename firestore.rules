rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true when the current user is a receptionist linked to this doctor
    function isLinkedReceptionist(doctorId) {
      return exists(/databases/$(database)/documents/receptionists/$(request.auth.uid))
        && get(/databases/$(database)/documents/receptionists/$(request.auth.uid)).data.doctorId == doctorId;
    }

    // Convenience: owner (doctor) OR their linked receptionist
    function isOwnerOrLinkedReceptionist(userId) {
      return request.auth != null
        && (request.auth.uid == userId || isLinkedReceptionist(userId));
    }

    // Returns true when the caller and target user share the same non-null organizationId
    // Used for multi-branch org switching — any member of an org can read other branches
    function isSameOrg(targetUserId) {
      let callerProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor).data;
      let targetProfile = get(/databases/$(database)/documents/users/$(targetUserId)/profile/doctor).data;
      return request.auth != null
        && callerProfile.get('organizationId', null) != null
        && callerProfile.get('organizationId', null) == targetProfile.get('organizationId', null);
    }

    // ── All clinic data lives under users/{userId}/... ──────────────────────
    match /users/{userId} {
      allow read, write: if isOwnerOrLinkedReceptionist(userId);
      allow read: if isSameOrg(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwnerOrLinkedReceptionist(userId);
      allow read: if isSameOrg(userId);
    }

    // ── Organizations ────────────────────────────────────────────────────────
    // Doctors can read their own org doc (to load branches in the sidebar).
    // All writes go through the Admin SDK (server-side only).
    match /organizations/{orgId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor)
             .data.get('organizationId', null) == orgId;
      allow write: if false;
    }

    // ── Invite codes ─────────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.data.doctorId == request.auth.uid;
    }

    // ── Receptionist records ─────────────────────────────────────────────────
    match /receptionists/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || (resource != null
                          && resource.data.doctorId == request.auth.uid));
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null
                    && (request.auth.uid == uid
                        || (resource != null
                            && resource.data.doctorId == request.auth.uid));
    }

    // ── Booking slugs ────────────────────────────────────────────────────────
    match /bookingSlugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.data.doctorId == request.auth.uid;
    }

    // ── collectionGroup("visits") ────────────────────────────────────────────
    match /{path=**}/visits/{visitId} {
      allow read: if request.auth != null
        && (resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(resource.data.doctorId)
            || isSameOrg(resource.data.doctorId));

      allow create: if request.auth != null
        && (request.resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(request.resource.data.doctorId));

      allow update, delete: if request.auth != null
        && (resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(resource.data.doctorId));
    }

  }
}
