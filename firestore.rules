rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true when the current user is a receptionist linked to this doctor
    function isLinkedReceptionist(doctorId) {
      return exists(/databases/$(database)/documents/receptionists/$(request.auth.uid))
        && get(/databases/$(database)/documents/receptionists/$(request.auth.uid)).data.doctorId == doctorId;
    }

    // Convenience: owner (doctor) OR their linked receptionist
    function isOwnerOrLinkedReceptionist(userId) {
      return request.auth != null
        && (request.auth.uid == userId || isLinkedReceptionist(userId));
    }

    // Org read: same org AND (allowedReaders is null/unset OR caller is in allowedReaders or allowedWriters)
    // null allowedReaders = backward-compat mode — any org member can read
    function isSameOrgRead(targetUserId) {
      let callerProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor).data;
      let targetProfile = get(/databases/$(database)/documents/users/$(targetUserId)/profile/doctor).data;
      let sameOrg = request.auth != null
        && callerProfile.get('organizationId', null) != null
        && callerProfile.get('organizationId', null) == targetProfile.get('organizationId', null);
      let allowedReaders = targetProfile.get('allowedReaders', null);
      let allowedWriters = targetProfile.get('allowedWriters', []);
      return sameOrg && (allowedReaders == null
        || request.auth.uid in allowedReaders
        || request.auth.uid in allowedWriters);
    }

    // Org write: same org AND caller is explicitly in allowedWriters
    function isSameOrgWrite(targetUserId) {
      let callerProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor).data;
      let targetProfile = get(/databases/$(database)/documents/users/$(targetUserId)/profile/doctor).data;
      return request.auth != null
        && callerProfile.get('organizationId', null) != null
        && callerProfile.get('organizationId', null) == targetProfile.get('organizationId', null)
        && request.auth.uid in targetProfile.get('allowedWriters', []);
    }

    // Returns true when the caller is a clinic_admin who has targetUserId in their managedDoctors list
    function isClinicAdmin(targetUserId) {
      let callerProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor).data;
      return request.auth != null
        && callerProfile.get('clinicRole', 'doctor') == 'clinic_admin'
        && targetUserId in callerProfile.get('managedDoctors', []);
    }

    // ── All clinic data lives under users/{userId}/... ──────────────────────
    match /users/{userId} {
      allow read:  if isOwnerOrLinkedReceptionist(userId) || isSameOrgRead(userId)  || isClinicAdmin(userId);
      allow write: if isOwnerOrLinkedReceptionist(userId) || isSameOrgWrite(userId) || isClinicAdmin(userId);
    }

    match /users/{userId}/{document=**} {
      allow read:  if isOwnerOrLinkedReceptionist(userId) || isSameOrgRead(userId)  || isClinicAdmin(userId);
      allow write: if isOwnerOrLinkedReceptionist(userId) || isSameOrgWrite(userId) || isClinicAdmin(userId);
    }

    // ── Organizations ────────────────────────────────────────────────────────
    // Doctors can read their own org doc (to load branches in the sidebar).
    // All writes go through the Admin SDK (server-side only).
    match /organizations/{orgId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/doctor)
             .data.get('organizationId', null) == orgId;
      allow write: if false;
    }

    // ── Invite codes ─────────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.data.doctorId == request.auth.uid;
    }

    // ── Receptionist records ─────────────────────────────────────────────────
    match /receptionists/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || (resource != null
                          && resource.data.doctorId == request.auth.uid));
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null
                    && (request.auth.uid == uid
                        || (resource != null
                            && resource.data.doctorId == request.auth.uid));
    }

    // ── Booking slugs ────────────────────────────────────────────────────────
    match /bookingSlugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.data.doctorId == request.auth.uid;
    }

    // ── collectionGroup("visits") ────────────────────────────────────────────
    match /{path=**}/visits/{visitId} {
      allow read: if request.auth != null
        && (resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(resource.data.doctorId)
            || isSameOrgRead(resource.data.doctorId));

      allow create: if request.auth != null
        && (request.resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(request.resource.data.doctorId));

      allow update, delete: if request.auth != null
        && (resource.data.doctorId == request.auth.uid
            || isLinkedReceptionist(resource.data.doctorId));
    }

  }
}
